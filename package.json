{
  "name": "tillefeuille",
  "version": "0.1.2",
  "description": "Merge multiple MVT sources into a multi-layer vector tile using Web-standard APIs.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kanahiro/tillefeuille.git"
  },
  "bugs": {
    "url": "https://github.com/Kanahiro/tillefeuille/issues"
  },
  "homepage": "https://github.com/Kanahiro/tillefeuille#readme",
  "packageManager": "pnpm@11.10.0",
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "build:demo": "vite build --base=/tillefeuille/ --outDir=pages --emptyOutDir",
    "test": "vitest run",
    "demo": "pnpm run build && vite demo --host 127.0.0.1",
    "prepack": "pnpm run build && pnpm test"
  },
  "keywords": [
    "mvt",
    "pmtiles",
    "vector-tile",
    "mapbox-vector-tile",
    "cloudflare-workers"
  ],
  "devDependencies": {
    "@types/node": "^26.1.1",
    "maplibre-gl": "^5.24.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "pmtiles": "^4.4.1"
  }
}
